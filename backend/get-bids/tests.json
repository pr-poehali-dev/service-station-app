{
  "tests": [
    {
      "name": "Ошибка без параметров",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400
    },
    {
      "name": "История заявок клиента",
      "method": "GET",
      "path": "/?client_id=1",
      "expectedStatus": 200
    },
    {
      "name": "Входящие заявки мастера",
      "method": "GET",
      "path": "/?master_id=1&mode=incoming",
      "expectedStatus": 200
    },
    {
      "name": "Список авто пользователя",
      "method": "GET",
      "path": "/?user_id=1&mode=cars",
      "expectedStatus": 200
    },
    {
      "name": "Добавить авто",
      "method": "POST",
      "path": "/",
      "body": { "action": "add_car", "user_id": 1, "brand": "Toyota", "model": "Camry", "year": 2021 },
      "expectedStatus": 200
    }
  ]
