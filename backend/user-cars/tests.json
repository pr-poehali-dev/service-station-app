{
  "tests": [
    {
      "name": "GET список авто — нет user_id",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET список авто пользователя",
      "method": "GET",
      "path": "/?user_id=1",
      "expectedStatus": 200,
      "expectedBody": {"cars": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST добавить авто",
      "method": "POST",
      "path": "/",
      "body": {"action": "add", "user_id": 1, "brand": "Toyota", "model": "Camry", "year": 2021, "vin": "JT2BF28K1W0122681"},
      "expectedStatus": 200,
      "expectedBody": {"car": {"brand": "Toyota"}},
      "bodyMatcher": "partial"
    }
  ]
}
